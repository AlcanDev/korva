#!/bin/sh
# Korva Sentinel — pre-commit hook
# Generated by: korva sentinel install
# Do not edit manually.

# Find the korva binary
if command -v korva >/dev/null 2>&1; then
    KORVA_BIN="korva"
elif [ -f "$(dirname "$0")/../../korva" ]; then
    KORVA_BIN="$(dirname "$0")/../../korva"
else
    # Cannot find korva — let the commit proceed with a warning
    echo "Warning: korva not found in PATH, skipping Sentinel validation."
    exit 0
fi

exec "$KORVA_BIN" sentinel run --hook=pre-commit
