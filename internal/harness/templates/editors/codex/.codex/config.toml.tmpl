# Codex CLI configuration — {{.Project}}
#
# Codex reads AGENTS.md automatically from the repo root (the open
# standard https://agents.md), so the universal harness contract is
# already in scope. This file adds two things on top:
#
#   1. Registers the Korva Vault MCP server so an in-editor agent can
#      invoke `vault_harness_*` tools directly (pick / start / done /
#      block features, materialize specs, run the EARS reviewer).
#   2. Documents the conventions the Codex agent should follow when
#      operating the harness state machine.
#
# Codex config reference:
#   https://developers.openai.com/codex/config-reference
#
# To remove this integration without uninstalling the harness, set
# `enabled = false` below.

# ── Korva Vault MCP server ────────────────────────────────────────────
# `korva-vault --mode mcp` speaks JSON-RPC over stdio. Make sure the
# binary is on PATH (typically `~/.korva/bin/korva-vault` or installed
# system-wide via `brew install korva`).
#
# `KORVA_EDITOR` is the canonical env var the vault reads to tag
# every interaction it records on this Codex session — feeds the
# Beacon "Editor adoption" widget. Set it to "" to opt out without
# disabling the MCP integration.
[mcp_servers.korva_vault]
command = "korva-vault"
args = ["--mode", "mcp"]
env = { KORVA_EDITOR = "codex" }
# enabled = false   # uncomment to keep the wiring but turn it off

# Optional — point Codex at a remote vault instead of a local one.
# Comment the [mcp_servers.korva_vault] block above and uncomment this
# one; supply the session token via the env var.
# [mcp_servers.korva_vault_remote]
# command = "korva"
# args = ["vault", "mcp-bridge", "--remote", "https://vault.example.com"]
# env = { KORVA_SESSION_TOKEN = "" }
