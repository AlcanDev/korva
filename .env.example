# Korva Vault — environment variables
# Copy to .env and fill in the values. Never commit .env to version control.
#
# Variables are grouped by scope:
#   • LOCAL DEV   — sensible defaults already set; override only when needed.
#   • PRODUCTION  — required for any internet-exposed deployment.
#   • OPTIONAL    — feature toggles; leave empty to disable.

# ─── Core (local-dev defaults work for `docker compose up`) ─────────────────
KORVA_VAULT_HOST=0.0.0.0
KORVA_VAULT_PORT=7437
KORVA_VAULT_MODE=http
KORVA_VAULT_DB=/data/vault.db
# Host port exposed by `docker compose up`. Coolify ignores this — it routes
# traffic through Traefik directly to the container's 7437.
KORVA_PORT=7437

# ─── CLI — point the `korva` binary at a remote vault ──────────────────────
# When unset the CLI talks to http://127.0.0.1:7437 (local-mode). Set this on
# a developer machine that should talk to the team's deployed vault:
#   export KORVA_VAULT_ENDPOINT=https://api.korva.dev
# Equivalently:
#   korva config set vault.endpoint https://api.korva.dev
KORVA_VAULT_ENDPOINT=

# ─── PRODUCTION — public hostnames + Traefik routing ────────────────────────
# Three subdomains, one container. The Traefik labels in docker-compose.yml
# wire each host to the same vault backend. See docs/DEPLOY_COOLIFY.md.
KORVA_APP_DOMAIN=app.korva.dev
KORVA_API_DOMAIN=api.korva.dev
KORVA_MCP_DOMAIN=mcp.korva.dev

# ─── PRODUCTION — CORS ──────────────────────────────────────────────────────
# Single origin allowed to call the API from a browser. Beacon is served from
# KORVA_APP_DOMAIN so that's the value here. Leave empty for local dev (the
# binary defaults to http://localhost:5173 — Vite's default port).
KORVA_CORS_ORIGIN=https://app.korva.dev

# ─── PRODUCTION — MCP HTTP transport ────────────────────────────────────────
# Default-deny: requests without a valid Authorization: Bearer <session_token>
# get a 401. Set to "true" ONLY for local development; never in production.
KORVA_MCP_ALLOW_ANONYMOUS=false

# ─── OPTIONAL — OIDC / SSO ──────────────────────────────────────────────────
# Required to enable Single Sign-On. Leave the four vars below empty to keep
# OIDC disabled. See docs/SELF_HOSTING_OIDC.md for IdP-specific setup recipes
# (Okta, Azure AD, Google Workspace, Authentik, Keycloak).
KORVA_OIDC_ISSUER_URL=
KORVA_OIDC_CLIENT_ID=
KORVA_OIDC_CLIENT_SECRET=
# In production this must match the API host above:
#   https://${KORVA_API_DOMAIN}/auth/oidc/callback
KORVA_OIDC_REDIRECT_URL=https://api.korva.dev/auth/oidc/callback
# Optional — comma-separated email-domain allowlist (e.g. "acme.io,partner.dev").
KORVA_OIDC_ALLOWED_DOMAINS=
# Optional — override the default scope list (openid,email,profile).
KORVA_OIDC_SCOPES=

# ─── OPTIONAL — Email (Resend) ──────────────────────────────────────────────
# Required only if you want email notifications (invites, license events).
# Use a SUBDOMAIN like send.korva.dev so its SPF/DKIM don't conflict with the
# apex domain's marketing sender. Get the API key at https://resend.com.
KORVA_EMAIL_API_KEY=
KORVA_EMAIL_FROM=no-reply@send.korva.dev
KORVA_EMAIL_FROM_NAME=Korva

# ─── OPTIONAL — Admin key ───────────────────────────────────────────────────
# Path on the HOST to the admin.key file. Mounted read-only into the container
# at /data/admin.key. Leave unset to disable header-based admin auth (session
# tokens still work). Default to /dev/null so the volume mount is a no-op.
KORVA_ADMIN_KEY_PATH=/dev/null

# ─── OPTIONAL — Licensing endpoint ──────────────────────────────────────────
# Only needed when running your own licensing server (Korva for Teams).
# Defaults to the public Korva licensing server when unset.
KORVA_LICENSING_ENDPOINT=https://licensing.korva.dev

# ─── OPTIONAL — Hive sync ───────────────────────────────────────────────────
# Enables cross-team knowledge sync. Configure in korva.config.json instead
# of env vars unless you need to override the config dynamically.
KORVA_HIVE_ENDPOINT=

# ─── OPTIONAL — Self-hosted licensing server ────────────────────────────────
# Required only when running forge/licensing-server (profile: teams).
# Generate your RSA-4096 key pair with: make keygen
KORVA_LICENSING_SECRET=change-me-in-production
KORVA_LICENSING_KEY_PEM=
# Alternative — file path inside the container:
# KORVA_LICENSING_PRIVATE_KEY_FILE=/run/secrets/licensing_key
