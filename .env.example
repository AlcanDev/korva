# Korva Vault — environment variables
# Copy to .env and fill in the values. Never commit .env to version control.

# ── Core ────────────────────────────────────────────────────────────────────
# Bind address — use 0.0.0.0 in Docker / Coolify, 127.0.0.1 for local-only
KORVA_VAULT_HOST=0.0.0.0
KORVA_VAULT_PORT=7437
KORVA_VAULT_MODE=http
KORVA_VAULT_DB=/data/vault.db

# ── Email delivery (Resend) — optional ──────────────────────────────────────
# Required only if you want email notifications for license events.
# Get your API key at https://resend.com
KORVA_EMAIL_API_KEY=
KORVA_EMAIL_FROM=no-reply@yourdomain.com
KORVA_EMAIL_FROM_NAME=Korva

# ── Licensing server endpoint — optional ────────────────────────────────────
# Only needed if you run your own licensing server (Korva for Teams).
# Defaults to the public Korva licensing server when unset.
KORVA_LICENSING_ENDPOINT=https://licensing.korva.dev

# ── Hive sync — optional ────────────────────────────────────────────────────
# Enables cross-team knowledge sync. Configure in korva.config.json instead
# of env vars unless you need to override the config dynamically.
KORVA_HIVE_ENDPOINT=

# ── Licensing server (only if self-hosting the licensing API) ───────────────
# Required to run forge/licensing-server.
# Generate your key pair with: make keygen
KORVA_LICENSING_ADMIN_SECRET=change-me-in-production
KORVA_LICENSING_PRIVATE_KEY_FILE=./priv.pem
# Alternative — inline PEM (useful for Docker secrets / Coolify env vars):
# KORVA_LICENSING_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n..."
